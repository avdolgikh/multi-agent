def _build_model_instance(model_cls: type[BaseModel], payload: dict[str, Any]) -> BaseModel:
    return model_cls.model_validate(payload)


def _phase_value(phase_module: Any, name: str) -> Any:
    target = name.upper()
    for candidate_name, candidate in vars(phase_module).items():
        if candidate_name.startswith("_"):
            continue
        if candidate_name.upper() == target and isinstance(candidate, str):
            return candidate
        if hasattr(candidate, target):
            return getattr(candidate, target)
    return target


def _build_with_semantics(callable_obj: Any, semantic_kwargs: dict[str, Any]) -> Any:
    signature = inspect.signature(callable_obj)
    param_names = list(signature.parameters)

    keyword_map = {
        "agent_id": ["agent_id", "agent", "id"],
        "name": ["team_name", "name", "team"],
        "model": ["model"],
        "provider": ["provider"],
        "canned_output": ["canned", "output", "payload", "result"],
        "fail": ["fail", "failure", "error", "broken"],
        "started": ["started"],
        "release": ["release"],
        "agents": ["agents", "members", "agent_list"],
        "agent_pairs": ["pairs", "pair", "agent_pairs", "member_pairs", "members", "outputs"],
        "bus": ["message_bus", "bus"],
        "event_store": ["event_store", "events", "store"],
        "aggregator": ["aggregator", "merge", "combine"],
        "validator": ["validator", "validation", "phase_validator"],
        "snapshot_store": ["snapshot_store", "snapshot", "snapshots"],
        "tracer_provider": ["tracer_provider", "tracer", "provider"],
        "teams": ["teams", "team_map", "discovery"],
        "synthesis_agent": ["synthesis", "report_agent", "report"],
        "expected_team_names": ["expected", "team_names"],
        "discovery_team_names": ["discovery", "team_names"],
        "deep_dive_team_names": ["deep", "team_names"],
        "phase_validator": ["phase", "validator"],
        "path": ["path", "input"],
        "task": ["task"],
        "input_data": ["input_data", "input", "payload", "data"],
        "trace_context": ["trace_context", "context"],
    }

    kwargs: dict[str, Any] = {}
    for semantic_name, value in semantic_kwargs.items():
        keywords = keyword_map.get(semantic_name, [semantic_name])
        chosen_param = None
        for param_name in param_names:
            lower = param_name.lower()
            if any(keyword in lower for keyword in keywords):
                chosen_param = param_name
                break
        if chosen_param is not None:
            kwargs[chosen_param] = value
    return callable_obj(**kwargs)


def _find_coroutine_method(obj: Any, *keywords: str) -> tuple[str, Any]:
    cls = obj if inspect.isclass(obj) else obj.__class__
    for name, value in inspect.getmembers(cls):
        if name.startswith("_") or not callable(value):
            continue
        lower = name.lower()
        if all(keyword.lower() in lower for keyword in keywords) and inspect.iscoroutinefunction(
            value
        ):
            bound = getattr(obj, name)
            return name, bound
    raise AssertionError(f"Could not find an async public method matching {keywords}")


def _find_public_callable(obj: Any, *keywords: str) -> tuple[str, Any]:
    cls = obj if inspect.isclass(obj) else obj.__class__
    for name, value in inspect.getmembers(cls):
        if name.startswith("_") or not callable(value):
            continue
        lower = name.lower()
        if all(keyword.lower() in lower for keyword in keywords):
            return name, getattr(obj, name)
    raise AssertionError(f"Could not find a public callable matching {keywords}")


def _find_model_by_payload(
    module: Any,
    payload: dict[str, Any],
    *,
    contains: tuple[str, ...] = (),
    exclude_keywords: tuple[str, ...] = (),
) -> tuple[str, type[BaseModel], BaseModel]:
    for name, model_cls in _public_model_classes(module):
        lower_name = name.lower()
        if any(keyword.lower() in lower_name for keyword in exclude_keywords):
            continue
        try:
            instance = model_cls.model_validate(payload)
        except Exception:  # noqa: BLE001
            continue
        if all(_contains_value(instance, needle) for needle in contains):
            return name, model_cls, instance
    raise AssertionError(
        f"Could not find a public model in {module.__name__ if hasattr(module, '__name__') else module} "
        f"that validates payload keys {sorted(payload)}"
    )


def _find_model_by_field_specs(
    module: Any,
    field_specs: list[tuple[tuple[str, ...], Any]],
    *,
    contains: tuple[str, ...] = (),
    exclude_keywords: tuple[str, ...] = (),
) -> tuple[str, type[BaseModel], BaseModel]:
    for name, model_cls in _public_model_classes(module):
        lower_name = name.lower()
        if any(keyword.lower() in lower_name for keyword in exclude_keywords):
            continue
        payload: dict[str, Any] = {}
        for keywords, value in field_specs:
            try:
                field_name = _find_model_field_any(model_cls, *keywords)
            except AssertionError:
                break
            payload[field_name] = value
        else:
            try:
                instance = model_cls.model_validate(payload)
            except Exception:  # noqa: BLE001
                continue
            if all(_contains_value(instance, needle) for needle in contains):
                return name, model_cls, instance
    raise AssertionError(
        f"Could not find a public model in {module.__name__ if hasattr(module, '__name__') else module} "
        f"matching field semantics {[keywords for keywords, _ in field_specs]}"
    )


def _find_phase_symbol(module: Any) -> tuple[str, Any]:
    phase_names = {
        "PENDING",
        "DISCOVERY",
        "DEEP_DIVE",
        "SYNTHESIS",
        "COMPLETED",
        "ROLLING_BACK",
        "FAILED",
    }
    for name, value in vars(module).items():
        if name.startswith("_"):
            continue
        if inspect.isclass(value):
            members = {candidate.upper() for candidate in dir(value) if candidate.isupper()}
            if {"DISCOVERY", "DEEP_DIVE", "SYNTHESIS"}.issubset(members):
                return name, value
        if isinstance(value, str) and value.upper() in phase_names:
            return name, value
    raise AssertionError(
        "Could not find a public phase symbol with discovery/deep-dive/synthesis values"
    )


def _extract_bool_field(model: Any) -> bool:
    if isinstance(model, bool):
        return model
    if isinstance(model, BaseModel):
        for field_name, field_info in model.model_fields.items():
            lower = field_name.lower()
            if any(token in lower for token in ("valid", "pass", "success", "ok")):
                return bool(getattr(model, field_name))
            annotation = getattr(field_info, "annotation", None)
            if annotation is bool:
                return bool(getattr(model, field_name))
        dumped = model.model_dump()
        for key, value in dumped.items():
            if any(token in key.lower() for token in ("valid", "pass", "success", "ok")):
                return bool(value)
    raise AssertionError(f"Could not determine a boolean result from {model!r}")


def _build_stub_agent(
    stubs_module: Any,
    *,
    agent_id: str,
    name: str,
    canned_output: dict[str, Any],
    fail: bool = False,
) -> Any:
    StubAgent = stubs_module.StubAgent
    return _build_with_semantics(
        StubAgent,
        {
            "agent_id": agent_id,
            "name": name,
            "model": "stub-model",
            "provider": "ollama",
            "canned_output": canned_output,
            "fail": fail,
        },
    )


class RecordingEventStore(InMemoryEventStore):
    def __init__(self) -> None:
        super().__init__()
        self.appended: list[tuple[str, Event]] = []

    async def append(self, stream: str, event: Event) -> int:
        self.appended.append((stream, event))
        return await super().append(stream, event)


class RecordingBus(InMemoryBus):
    def __init__(self) -> None:
        super().__init__()
        self.published: list[tuple[str, Message]] = []

    async def publish(self, topic: str, message: Message) -> None:
        self.published.append((topic, message))
        await super().publish(topic, message)


class BarrierStubAgent:
    def __init__(
        self,
        wrapped_agent: Any,
        *,
        started: asyncio.Event,
        release: asyncio.Event,
        recorded_trace_contexts: list[dict[str, Any]],
    ) -> None:
        self.wrapped_agent = wrapped_agent
        self.started = started
        self.release = release
        self.recorded_trace_contexts = recorded_trace_contexts

    def __getattr__(self, item: str) -> Any:
        return getattr(self.wrapped_agent, item)

    async def execute(self, task: AgentTask) -> AgentResult:
        self.recorded_trace_contexts.append(task.trace_context or {})
        self.started.set()
        await self.release.wait()
        return await self.wrapped_agent.execute(task)


class RecordingStubAgent(BaseAgent):
    def __init__(self, wrapped_agent: Any) -> None:
        super().__init__(
            agent_id=getattr(wrapped_agent, "agent_id"),
            name=getattr(wrapped_agent, "name"),
            model=getattr(wrapped_agent, "model", "stub-model"),
            provider=getattr(wrapped_agent, "provider", "ollama"),
            tools=[],
            system_prompt="",
            base_url=None,
        )
        self.wrapped_agent = wrapped_agent
        self.seen_tasks: list[AgentTask] = []

    def __getattr__(self, item: str) -> Any:
        return getattr(self.wrapped_agent, item)

    async def execute(self, task: AgentTask) -> AgentResult:
        self.seen_tasks.append(task)
        return await self.wrapped_agent.execute(task)


def _make_team(
    team_module: Any,
    *,
    name: str,
    agents: list[Any],
    bus: Any,
    event_store: Any,
    aggregator: Any,
    tracer_provider: Any | None = None,
) -> Any:
    Team = team_module.Team
    return _build_with_semantics(
        Team,
        {
            "name": name,
            "agents": agents,
            "bus": bus,
            "event_store": event_store,
            "aggregator": aggregator,
            "tracer_provider": tracer_provider,
        },
    )


def _make_stub_team(
    root_module: Any,
    *,
    name: str,
    agent_pairs: list[tuple[str, dict[str, Any]]],
    bus: Any,
    event_store: Any,
    tracer_provider: Any | None = None,
) -> Any:
    make_stub_team = getattr(root_module, "make_stub_team")
    return _build_with_semantics(
        make_stub_team,
        {
            "name": name,
            "agent_pairs": agent_pairs,
            "bus": bus,
            "event_store": event_store,
            "tracer_provider": tracer_provider,
        },
    )


def _make_validator(orchestrator_module: Any) -> Any:
    _, Validator = _find_public_member(orchestrator_module, "validator", kind="class")
    return _build_with_semantics(
        Validator,
        {
            "expected_team_names": {
                "DISCOVERY": {"structure", "dependencies"},
                "DEEP_DIVE": {"security", "quality"},
                "SYNTHESIS": set(),
            },
            "discovery_team_names": {"structure", "dependencies"},
            "deep_dive_team_names": {"security", "quality"},
        },
    )


def _make_orchestrator(
    orchestrator_module: Any,
    *,
    discovery_structure_team: Any,
    discovery_dependencies_team: Any,
    deep_dive_security_team: Any,
    deep_dive_quality_team: Any,
    synthesis_agent: Any,
    validator: Any,
    event_store: Any,
    snapshot_store: Any,
    bus: Any,
    tracer_provider: Any,
) -> Any:
    _, Orchestrator = _find_public_member(orchestrator_module, "orchestrator", kind="class")
    return _build_with_semantics(
        Orchestrator,
        {
            "teams": {
                "DISCOVERY": {
                    "structure": discovery_structure_team,
                    "dependencies": discovery_dependencies_team,
                },
                "DEEP_DIVE": {
                    "security": deep_dive_security_team,
                    "quality": deep_dive_quality_team,
                },
            },
            "structure_team": discovery_structure_team,
            "dependencies_team": discovery_dependencies_team,
            "security_team": deep_dive_security_team,
            "quality_team": deep_dive_quality_team,
            "synthesis_agent": synthesis_agent,
            "validator": validator,
            "phase_validator": validator,
            "event_store": event_store,
            "snapshot_store": snapshot_store,
            "bus": bus,
            "tracer_provider": tracer_provider,
        },
    )


def _build_project_report(models_module: Any) -> BaseModel:
    _, project_report_cls, project_report = _find_model_by_payload(
        models_module,
        _sample_project_report_payload(),
        contains=("All sections are present.",),
    )
    assert issubclass(project_report_cls, BaseModel)
    return project_report


def _normalize_phase(value: Any) -> str:
    if value is None:
        return ""
    if hasattr(value, "name"):
        return str(value.name)
    return str(value)


def _find_topic_helper(events_module: Any) -> tuple[str, Any]:
    for name, value in vars(events_module).items():
        if not callable(value) or name.startswith("_"):
            continue
        lower = name.lower()
        if "topic" in lower:
            return name, value
    raise AssertionError("Expected an event topic helper in hybrid.project_analysis.events")


def _find_phase_model(events_module: Any, *keywords: str) -> type[BaseModel]:
    for name, value in vars(events_module).items():
        if not inspect.isclass(value) or not issubclass(value, BaseModel):
            continue
        lower = name.lower()
        if all(keyword.lower() in lower for keyword in keywords):
            return value
    raise AssertionError(f"Could not find an event model matching keywords {keywords}")


def _collect_uppercase_string_constants(module: Any) -> dict[str, str]:
    return {
        name: value
        for name, value in vars(module).items()
        if name.isupper() and isinstance(value, str)
    }


def _build_phase_model_instance(model_cls: type[BaseModel], *, extras: dict[str, Any]) -> BaseModel:
    payload: dict[str, Any] = {}
    for keyword, value in extras.items():
        payload[_find_model_field(model_cls, keyword)] = value
    return model_cls.model_validate(payload)


def _build_structured_result_payload(key: str, value: Any) -> dict[str, Any]:
    return {key: value}


def _first_matching_span(spans: list[Any], *, attribute: str, value: str) -> Any:
    for span in spans:
        if span.attributes.get(attribute) == value:
            return span
    raise AssertionError(f"Could not find span with {attribute}={value!r}")


def _children_of(span: Any, spans: list[Any]) -> list[Any]:
    return [
        candidate
        for candidate in spans
        if candidate.parent is not None and candidate.parent.span_id == span.context.span_id
    ]


def _span_containing_value(spans: list[Any], needle: str) -> Any:
    for span in spans:
        if _contains_value(span.attributes, needle):
            return span
    raise AssertionError(f"Could not find span containing value {needle!r}")


def _phase_spans(spans: list[Any]) -> list[Any]:
    return [
        span for span in spans if "phase" in {str(key).lower() for key in span.attributes.keys()}
    ]


class _BaseBarrierAgent(BaseAgent):
    def __init__(
        self,
        *,
        agent_id: str,
        name: str,
        canned_output: dict[str, Any],
        started: asyncio.Event,
        release: asyncio.Event,
        recorder: list[dict[str, Any]],
        fail: bool = False,
    ) -> None:
        super().__init__(
            agent_id=agent_id,
            name=name,
            model="stub-model",
            provider="ollama",
            tools=[],
            system_prompt="",
            base_url=None,
        )
        self._canned_output = canned_output
        self._started = started
        self._release = release
        self._recorder = recorder
        self._fail = fail

    async def execute(self, task: AgentTask) -> AgentResult:
        self._recorder.append(task.trace_context or {})
        self._started.set()
        await self._release.wait()
        if self._fail:
            return AgentResult(
                task_id=task.task_id,
                agent_id=self.agent_id,
                output_data={},
                status="failure",
                error="forced failure",
                duration_ms=0.0,
                trace_context=task.trace_context or {},
            )
        return AgentResult(
            task_id=task.task_id,
            agent_id=self.agent_id,
            output_data=dict(self._canned_output),
            status="success",
            error=None,
            duration_ms=0.0,
            trace_context=task.trace_context or {},
        )


@pytest.mark.asyncio
async def test_public_api_reexports_from_package_root():
    modules = _load_hybrid_modules()

    discovered_symbols = [
        _find_phase_symbol,
        lambda module: _find_model_by_payload(
            module, _sample_structure_payload(), contains=("compute",)
        )[:2],
        lambda module: _find_model_by_payload(
            module, _sample_dependency_payload(), contains=("requests",)
        )[:2],
        lambda module: _find_model_by_payload(
            module, _sample_security_payload(), contains=("secret",)
        )[:2],
        lambda module: _find_model_by_payload(
            module, _sample_quality_payload(), contains=("cyclomatic_complexity",)
        )[:2],
        lambda module: _find_model_by_payload(
            module, _sample_project_report_payload(), contains=("All sections are present.",)
        )[:2],
        lambda module: _find_model_by_field_specs(
            module,
            [
                (("workflow", "workflow_id", "analysis", "run"), "workflow-1"),
                (("phase", "state", "step"), "DISCOVERY"),
                (
                    ("result", "results", "output", "report", "data"),
                    {"structure": _sample_structure_payload()},
                ),
            ],
        )[:2],
        lambda module: _find_model_by_field_specs(
            module,
            [
                (("valid", "passed", "success", "ok", "approved"), True),
                (("error", "errors", "issues", "problem", "message"), []),
            ],
        )[:2],
        lambda module: _find_public_member(module, "team", kind="class"),
        lambda module: _find_public_member(module, "orchestrator", kind="class"),
        lambda module: _find_public_member(module, "phase", "validator", kind="class"),
        lambda module: _find_public_member(module, "stub", "agent", kind="class"),
        lambda module: _find_public_member(module, "stub", "team", kind="callable"),
    ]

    for finder in discovered_symbols:
        package_name, package_value = finder(modules.package)
        assert getattr(modules.root, package_name) is package_value


def test_domain_models_are_pydantic_data_containers():
    modules = _load_hybrid_modules()
    models = modules.models

    for _, model_cls in (
        _find_model_by_payload(models, _sample_structure_payload(), contains=("compute",))[:2],
        _find_model_by_payload(models, _sample_dependency_payload(), contains=("requests",))[:2],
        _find_model_by_payload(models, _sample_security_payload(), contains=("secret",))[:2],
        _find_model_by_payload(
            models, _sample_quality_payload(), contains=("cyclomatic_complexity",)
        )[:2],
        _find_model_by_payload(
            models, _sample_project_report_payload(), contains=("All sections are present.",)
        )[:2],
        _find_model_by_field_specs(
            models,
            [
                (("workflow", "workflow_id", "analysis", "run"), "workflow-1"),
                (("phase", "state", "step"), "DISCOVERY"),
                (
                    ("result", "results", "output", "report", "data"),
                    {"structure": _sample_structure_payload()},
                ),
            ],
            contains=("workflow-1", "discovery"),
        )[:2],
        _find_model_by_field_specs(
            models,
            [
                (("valid", "passed", "success", "ok", "approved"), True),
                (("error", "errors", "issues", "problem", "message"), []),
            ],
        )[:2],
    ):
        assert inspect.isclass(model_cls)
        assert issubclass(model_cls, BaseModel)
        assert _public_method_names(model_cls) == []

    structure_cls = _find_model_by_payload(
        models, _sample_structure_payload(), contains=("compute",)
    )[1]
    dependency_cls = _find_model_by_payload(
        models, _sample_dependency_payload(), contains=("requests",)
    )[1]
    security_cls = _find_model_by_payload(models, _sample_security_payload(), contains=("secret",))[
        1
    ]
    quality_cls = _find_model_by_payload(
        models, _sample_quality_payload(), contains=("cyclomatic_complexity",)
    )[1]
    project_report_cls = _find_model_by_payload(
        models, _sample_project_report_payload(), contains=("All sections are present.",)
    )[1]

    structure = _build_model_instance(structure_cls, _sample_structure_payload())
    dependency = _build_model_instance(dependency_cls, _sample_dependency_payload())
    security = _build_model_instance(security_cls, _sample_security_payload())
    quality = _build_model_instance(quality_cls, _sample_quality_payload())
    project_report = _build_model_instance(project_report_cls, _sample_project_report_payload())

    assert _contains_value(structure, "compute")
    assert _contains_value(dependency, "requests")
    assert _contains_value(security, "secret")
    assert _contains_value(quality, "cyclomatic_complexity")
    assert _contains_value(project_report, "All sections are present.")

    _, _analysis_state_cls, state = _find_model_by_field_specs(
        models,
        [
            (("workflow", "workflow_id", "analysis", "run"), "workflow-1"),
            (("phase", "state", "step"), "DISCOVERY"),
            (
                ("result", "results", "output", "report", "data"),
                {"structure": _sample_structure_payload()},
            ),
        ],
        contains=("workflow-1", "discovery"),
    )
    assert _contains_value(state, "workflow-1")
    assert _contains_value(state, "discovery")

    _, _validation_cls, validation_result = _find_model_by_field_specs(
        models,
        [
            (("valid", "passed", "success", "ok", "approved"), True),
            (("error", "errors", "issues", "problem", "message"), []),
        ],
    )
    assert _extract_bool_field(validation_result) is True

    _, result_model_cls, phase_result = _find_model_by_field_specs(
        models,
        [
            (("phase", "state", "step"), "DISCOVERY"),
            (
                ("result", "results", "output", "report", "data"),
                _sample_structure_payload(),
            ),
        ],
        contains=("DISCOVERY", "compute"),
        exclude_keywords=("validation",),
    )
    assert _public_method_names(result_model_cls) == []

    assert _contains_value(phase_result, "DISCOVERY")
    assert _contains_value(phase_result, "compute")


def test_event_vocab_exposes_topic_helper_and_payload_models():
    modules = _load_hybrid_modules()
    events = modules.events

    topic_helper_name, topic_helper = _find_topic_helper(events)
    assert callable(topic_helper)

    topic = topic_helper("structure", "completed")
    assert isinstance(topic, str)
    assert "structure" in topic.lower()
    assert "completed" in topic.lower()
    assert topic_helper_name.lower().endswith("topic") or "topic" in topic_helper_name.lower()

    team_completed_cls = _find_phase_model(events, "team", "complete")
    phase_validated_cls = _find_phase_model(events, "phase", "valid")
    phase_failed_cls = _find_phase_model(events, "phase", "fail")

    assert issubclass(team_completed_cls, BaseModel)
    assert issubclass(phase_validated_cls, BaseModel)
    assert issubclass(phase_failed_cls, BaseModel)

    team_fields = {name.lower() for name in team_completed_cls.model_fields}
    validated_fields = {name.lower() for name in phase_validated_cls.model_fields}
    failed_fields = {name.lower() for name in phase_failed_cls.model_fields}

    assert any("team" in name for name in team_fields)
    assert any("phase" in name for name in validated_fields)
    assert any("next" in name for name in validated_fields)
    assert any("phase" in name for name in failed_fields)
    assert any("rollback" in name or "compens" in name for name in failed_fields)

    constants = _collect_uppercase_string_constants(events)
    assert len(constants) >= 3
    assert any(
        "team" in value.lower() and "complete" in value.lower() for value in constants.values()
    )
    assert any(
        "phase" in value.lower() and "valid" in value.lower() for value in constants.values()
    )
    assert any("phase" in value.lower() and "fail" in value.lower() for value in constants.values())


