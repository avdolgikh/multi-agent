@pytest.mark.asyncio
async def test_phase_validator_is_async_and_enforces_phase_requirements():
    modules = _load_hybrid_modules()
    validator = _make_validator(modules.orchestrator)

    assert inspect.iscoroutinefunction(validator.validate)

    discovery_phase = _phase_value(modules.orchestrator, "DISCOVERY")
    deep_dive_phase = _phase_value(modules.orchestrator, "DEEP_DIVE")
    synthesis_phase = _phase_value(modules.orchestrator, "SYNTHESIS")

    missing_discovery = {
        "structure": _sample_structure_payload(),
    }
    valid_discovery = {
        "structure": _sample_structure_payload(),
        "dependencies": _sample_dependency_payload(),
    }
    invalid_synthesis = {
        "structure": _sample_structure_payload(),
        "dependencies": _sample_dependency_payload(),
        "security": _sample_security_payload(),
        "quality": _sample_quality_payload(),
        "summary": "",
    }
    valid_synthesis = _sample_project_report_payload()

    discovery_missing_result = await validator.validate(discovery_phase, missing_discovery)
    discovery_valid_result = await validator.validate(discovery_phase, valid_discovery)
    deep_dive_valid_result = await validator.validate(
        deep_dive_phase,
        {
            "security": _sample_security_payload(),
            "quality": _sample_quality_payload(),
        },
    )
    synthesis_invalid_result = await validator.validate(synthesis_phase, invalid_synthesis)
    synthesis_valid_result = await validator.validate(synthesis_phase, valid_synthesis)

    assert _extract_bool_field(discovery_missing_result) is False
    assert _extract_bool_field(discovery_valid_result) is True
    assert _extract_bool_field(deep_dive_valid_result) is True
    assert _extract_bool_field(synthesis_invalid_result) is False
    assert _extract_bool_field(synthesis_valid_result) is True


@pytest.mark.asyncio
async def test_stub_agent_returns_canned_output_without_llm_call_and_spans_execute(monkeypatch):
    modules = _load_hybrid_modules()
    provider, exporter = _setup_tracing("hybrid-stub-agent-tests")

    called_llm = False

    async def _fail_if_called(*args: Any, **kwargs: Any) -> Any:
        nonlocal called_llm
        called_llm = True
        raise AssertionError("StubAgent must not call the LLM")

    monkeypatch.setattr(BaseAgent, "call_llm", _fail_if_called)

    agent = _build_stub_agent(
        modules.stubs,
        agent_id="stub-1",
        name="Stub Agent",
        canned_output={"result": "ok"},
    )

    with provider.get_tracer("hybrid.tests").start_as_current_span("parent") as parent_span:
        task = AgentTask(
            task_id="task-1",
            input_data={"prompt": "ignored"},
            metadata={},
            trace_context=inject_context(),
        )
        result = await agent.execute(task)

    provider.force_flush()
    spans = exporter.get_finished_spans()
    assert called_llm is False
    assert result.status == "success"
    assert result.output_data == {"result": "ok"}

    parent_trace_id = parent_span.get_span_context().trace_id
    child_spans = [
        span
        for span in spans
        if span.parent is not None
        and span.parent.trace_id == parent_trace_id
        and span.parent.span_id == parent_span.get_span_context().span_id
    ]
    assert child_spans
    assert any("execute" in span.name.lower() for span in child_spans)

    failing_agent = _build_stub_agent(
        modules.stubs,
        agent_id="stub-fail",
        name="Failing Stub Agent",
        canned_output={"result": "ignored"},
        fail=True,
    )
    failure_result = await failing_agent.execute(
        AgentTask(
            task_id="task-2",
            input_data={},
            metadata={},
            trace_context={},
        )
    )
    assert failure_result.status == "failure"
    assert failure_result.error


@pytest.mark.asyncio
async def test_team_runs_member_agents_concurrently_publishes_completion_and_propagates_trace_context():
    modules = _load_hybrid_modules()
    provider, exporter = _setup_tracing("hybrid-team-tests")
    bus = RecordingBus()
    event_store = RecordingEventStore()
    started_one = asyncio.Event()
    started_two = asyncio.Event()
    release = asyncio.Event()
    trace_contexts_one: list[dict[str, Any]] = []
    trace_contexts_two: list[dict[str, Any]] = []

    agent_one = _BaseBarrierAgent(
        agent_id="structure-1",
        name="Structure One",
        canned_output={"structure": {"marker": "one"}},
        started=started_one,
        release=release,
        recorder=trace_contexts_one,
    )
    agent_two = _BaseBarrierAgent(
        agent_id="structure-2",
        name="Structure Two",
        canned_output={"dependencies": {"marker": "two"}},
        started=started_two,
        release=release,
        recorder=trace_contexts_two,
    )

    team = _make_team(
        modules.team,
        name="structure",
        agents=[agent_one, agent_two],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )

    _entry_name, team_run = _find_coroutine_method(team, "run", "execute")
    task = AgentTask(
        task_id="team-task",
        input_data={"input_path": "demo.py"},
        metadata={},
        trace_context={},
    )

    with provider.get_tracer("hybrid.tests").start_as_current_span("team-parent") as parent_span:
        task.trace_context = inject_context()
        run_task = asyncio.create_task(
            team_run(task=task)
            if "task" in inspect.signature(team_run).parameters
            else team_run(input_data=task.input_data, trace_context=task.trace_context)
        )
        await asyncio.wait_for(started_one.wait(), timeout=1.0)
        await asyncio.wait_for(started_two.wait(), timeout=1.0)
        release.set()
        result = await asyncio.wait_for(run_task, timeout=1.0)

    provider.force_flush()
    spans = exporter.get_finished_spans()
    merged = _normalize_mapping(result)

    assert merged["structure"]["marker"] == "one"
    assert merged["dependencies"]["marker"] == "two"
    assert len(event_store.appended) == 2
    assert all("structure" in stream.lower() for stream, _ in event_store.appended)
    assert bus.published
    assert any(
        "structure" in topic.lower()
        and ("complete" in topic.lower() or "completed" in topic.lower())
        for topic, _ in bus.published
    )
    assert len(trace_contexts_one) == 1
    assert len(trace_contexts_two) == 1
    assert (
        extract_context(trace_contexts_one[0]).trace_id == parent_span.get_span_context().trace_id
    )
    assert (
        extract_context(trace_contexts_two[0]).trace_id == parent_span.get_span_context().trace_id
    )

    team_spans = [
        span
        for span in spans
        if span.parent is not None
        and span.parent.span_id == parent_span.get_span_context().span_id
        and _children_of(span, spans)
    ]
    assert team_spans
    team_span = team_spans[0]
    assert team_span.parent is not None
    assert team_span.parent.trace_id == parent_span.get_span_context().trace_id
    assert any("execute" in child.name.lower() for child in _children_of(team_span, spans))


@pytest.mark.asyncio
async def test_team_failure_surfaces_on_completion_message_without_raising():
    modules = _load_hybrid_modules()
    provider, _exporter = _setup_tracing("hybrid-team-failure-tests")
    bus = RecordingBus()
    event_store = RecordingEventStore()
    started = asyncio.Event()
    release = asyncio.Event()
    trace_contexts: list[dict[str, Any]] = []

    success_agent = _BaseBarrierAgent(
        agent_id="security-1",
        name="Security One",
        canned_output={"security": {"marker": "ok"}},
        started=started,
        release=release,
        recorder=trace_contexts,
    )
    failure_agent = _BaseBarrierAgent(
        agent_id="security-2",
        name="Security Two",
        canned_output={},
        started=asyncio.Event(),
        release=release,
        recorder=trace_contexts,
        fail=True,
    )

    team = _make_team(
        modules.team,
        name="security",
        agents=[success_agent, failure_agent],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )

    _entry_name, team_run = _find_coroutine_method(team, "run", "execute")
    run_args: dict[str, Any] = {}
    if "task" in inspect.signature(team_run).parameters:
        run_args["task"] = AgentTask(
            task_id="team-failure-task",
            input_data={},
            metadata={},
            trace_context=inject_context(),
        )
    else:
        run_args["input_data"] = {}
        run_args["trace_context"] = inject_context()

    run_task = asyncio.create_task(team_run(**run_args))
    await asyncio.wait_for(started.wait(), timeout=1.0)
    release.set()
    result = await asyncio.wait_for(run_task, timeout=1.0)

    merged = _normalize_mapping(result)
    assert merged["security"]["marker"] == "ok"
    assert len(event_store.appended) == 2
    assert bus.published
    completion_payload = bus.published[-1][1].payload
    assert _contains_value(completion_payload, "failure") or _contains_value(
        completion_payload, "boom"
    )
    assert _contains_value(completion_payload, "security")


@pytest.mark.asyncio
async def test_orchestrator_state_machine_happy_path_snapshots_and_trace_hierarchy(tmp_path):
    modules = _load_hybrid_modules()
    provider, exporter = _setup_tracing("hybrid-orchestrator-tests")
    bus = RecordingBus()
    event_store = RecordingEventStore()
    snapshot_store = SnapshotStore()

    discovery_structure_team = _make_stub_team(
        modules.root,
        name="structure",
        agent_pairs=[("structure-agent", {"structure": _sample_structure_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    discovery_dependencies_team = _make_stub_team(
        modules.root,
        name="dependencies",
        agent_pairs=[("dependencies-agent", {"dependencies": _sample_dependency_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    deep_dive_security_team = _make_stub_team(
        modules.root,
        name="security",
        agent_pairs=[("security-agent", {"security": _sample_security_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    deep_dive_quality_team = _make_stub_team(
        modules.root,
        name="quality",
        agent_pairs=[("quality-agent", {"quality": _sample_quality_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )

    report_model = _build_project_report(modules.models)
    synthesis_agent = RecordingStubAgent(
        _build_stub_agent(
            modules.stubs,
            agent_id="report-agent",
            name="Report Agent",
            canned_output=report_model.model_dump(),
        )
    )

    orchestrator = _make_orchestrator(
        modules.orchestrator,
        discovery_structure_team=discovery_structure_team,
        discovery_dependencies_team=discovery_dependencies_team,
        deep_dive_security_team=deep_dive_security_team,
        deep_dive_quality_team=deep_dive_quality_team,
        synthesis_agent=synthesis_agent,
        validator=_make_validator(modules.orchestrator),
        event_store=event_store,
        snapshot_store=snapshot_store,
        bus=bus,
        tracer_provider=provider,
    )

    path = tmp_path / "demo.py"
    path.write_text("def demo():\n    return 1\n", encoding="utf-8")

    run_task = asyncio.create_task(orchestrator.run(str(path)))

    report = await asyncio.wait_for(run_task, timeout=1.0)
    provider.force_flush()

    assert isinstance(report, BaseModel)
    assert _contains_value(report, "All sections are present.")

    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "team" in topic.lower() and "complete" in topic.lower()
            ]
        )
        == 4
    )
    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "phase" in topic.lower() and "valid" in topic.lower()
            ]
        )
        == 3
    )
    validated_payloads = [
        _normalize_mapping(message.payload)
        for topic, message in bus.published
        if "phase" in topic.lower() and "valid" in topic.lower()
    ]
    assert len(validated_payloads) == 3
    assert any(
        _contains_value(payload, "discovery") and _contains_value(payload, "deep_dive")
        for payload in validated_payloads
    )
    assert any(
        _contains_value(payload, "deep_dive") and _contains_value(payload, "synthesis")
        for payload in validated_payloads
    )
    assert any(
        _contains_value(payload, "synthesis") and _contains_value(payload, "completed")
        for payload in validated_payloads
    )
    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "phase" in topic.lower() and "fail" in topic.lower()
            ]
        )
        == 0
    )

    analysis_state = getattr(orchestrator, "analysis_state")
    assert analysis_state is not None
    assert _contains_value(analysis_state, "completed")

    history = await snapshot_store.history(
        getattr(
            analysis_state,
            "workflow_id",
            next(iter(getattr(snapshot_store, "_workflow_index", {})), ""),
        )
    )
    assert history
    history_phases = [
        _normalize_phase(
            _mapping_value_by_key_keywords(
                snapshot.state,
                ("phase",),
                ("status",),
                ("state",),
                ("step",),
            )
        ).lower()
        for snapshot in history
    ]
    assert "discovery" in history_phases
    assert "deep_dive" in history_phases
    assert "synthesis" in history_phases
    assert history_phases.index("discovery") < history_phases.index("deep_dive")
    assert history_phases.index("deep_dive") < history_phases.index("synthesis")

    assert len(synthesis_agent.seen_tasks) == 1
    synthesis_input = synthesis_agent.seen_tasks[0].input_data
    assert _contains_value(synthesis_input, "structure")
    assert _contains_value(synthesis_input, "dependencies")
    assert _contains_value(synthesis_input, "security")
    assert _contains_value(synthesis_input, "quality")

    spans = exporter.get_finished_spans()
    root_spans = [span for span in spans if span.parent is None]
    assert root_spans
    root_span = root_spans[0]

    phase_spans = _children_of(root_span, spans)
    assert len(phase_spans) == 3

    phases_with_team_children = [
        phase
        for phase in phase_spans
        if any(_children_of(child, spans) for child in _children_of(phase, spans))
    ]
    assert len(phases_with_team_children) == 2

    for phase in phases_with_team_children:
        team_spans = [child for child in _children_of(phase, spans) if _children_of(child, spans)]
        assert team_spans
        for team_span in team_spans:
            assert any("execute" in child.name.lower() for child in _children_of(team_span, spans))

    synthesis_phase_spans = [
        phase
        for phase in phase_spans
        if any("execute" in child.name.lower() for child in _children_of(phase, spans))
        and not any(_children_of(child, spans) for child in _children_of(phase, spans))
    ]
    assert len(synthesis_phase_spans) == 1
    synthesis_children = _children_of(synthesis_phase_spans[0], spans)
    assert any("execute" in child.name.lower() for child in synthesis_children)


@pytest.mark.asyncio
async def test_orchestrator_invalid_transition_raises_via_public_state(tmp_path):
    modules = _load_hybrid_modules()
    provider, _exporter = _setup_tracing("hybrid-transition-tests")
    bus = RecordingBus()
    event_store = RecordingEventStore()
    snapshot_store = SnapshotStore()

    discovery_structure_team = _make_stub_team(
        modules.root,
        name="structure",
        agent_pairs=[("structure-agent", {"structure": _sample_structure_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    discovery_dependencies_team = _make_stub_team(
        modules.root,
        name="dependencies",
        agent_pairs=[("dependencies-agent", {"dependencies": _sample_dependency_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    deep_dive_security_team = _make_stub_team(
        modules.root,
        name="security",
        agent_pairs=[("security-agent", {"security": _sample_security_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )
    deep_dive_quality_team = _make_stub_team(
        modules.root,
        name="quality",
        agent_pairs=[("quality-agent", {"quality": _sample_quality_payload()})],
        bus=bus,
        event_store=event_store,
        tracer_provider=provider,
    )

    report_model = _build_project_report(modules.models)
    synthesis_agent = RecordingStubAgent(
        _build_stub_agent(
            modules.stubs,
            agent_id="report-agent",
            name="Report Agent",
            canned_output=report_model.model_dump(),
        )
    )

    orchestrator = _make_orchestrator(
        modules.orchestrator,
        discovery_structure_team=discovery_structure_team,
        discovery_dependencies_team=discovery_dependencies_team,
        deep_dive_security_team=deep_dive_security_team,
        deep_dive_quality_team=deep_dive_quality_team,
        synthesis_agent=synthesis_agent,
        validator=_make_validator(modules.orchestrator),
        event_store=event_store,
        snapshot_store=snapshot_store,
        bus=bus,
        tracer_provider=provider,
    )

    path = tmp_path / "invalid-transition.py"
    path.write_text("def demo():\n    return 1\n", encoding="utf-8")

    await orchestrator.run(str(path))

    try:
        _, transition = _find_public_callable(orchestrator, "transition")
    except AssertionError:
        _, transition = _find_public_callable(orchestrator, "advance")

    invalid_target = _phase_value(modules.orchestrator, "DISCOVERY")
    completed_state = _phase_value(modules.orchestrator, "COMPLETED")
    signature = inspect.signature(transition)
    call_args: list[Any] = []
    call_kwargs: dict[str, Any] = {}
    for parameter in signature.parameters.values():
        if parameter.kind in (inspect.Parameter.VAR_POSITIONAL, inspect.Parameter.VAR_KEYWORD):
            continue
        lower = parameter.name.lower()
        value = (
            completed_state
            if any(token in lower for token in ("from", "current", "source", "before"))
            else invalid_target
        )
        if parameter.kind == inspect.Parameter.KEYWORD_ONLY:
            call_kwargs[parameter.name] = value
        else:
            call_args.append(value)

    with pytest.raises(Exception) as excinfo:
        outcome = transition(*call_args, **call_kwargs)
        if inspect.isawaitable(outcome):
            await outcome
    message = str(excinfo.value).strip().lower()
    assert message
    assert "completed" in message and "discovery" in message
    assert "transition" in message or "invalid" in message or "cannot" in message


@pytest.mark.asyncio
async def test_orchestrator_validation_failure_rolls_back_and_preserves_prior_results(tmp_path):
    modules = _load_hybrid_modules()
    provider, _exporter = _setup_tracing("hybrid-orchestrator-failure-tests")
    bus = RecordingBus()
    event_store = RecordingEventStore()
    snapshot_store = SnapshotStore()

    discovery_release = asyncio.Event()
    deep_dive_release = asyncio.Event()
    started_discovery = asyncio.Event()
    started_dependencies = asyncio.Event()
    started_security = asyncio.Event()
    started_quality = asyncio.Event()

    discovery_structure_agent = _BaseBarrierAgent(
        agent_id="structure-agent",
        name="Structure Agent",
        canned_output={"structure": {"marker": "kept"}},
        started=started_discovery,
        release=discovery_release,
        recorder=[],
    )
    discovery_dependencies_agent = _BaseBarrierAgent(
        agent_id="dependencies-agent",
        name="Dependencies Agent",
        canned_output={"dependencies": {"marker": "kept"}},
        started=started_dependencies,
        release=discovery_release,
        recorder=[],
    )
    deep_dive_security_agent = _BaseBarrierAgent(
        agent_id="security-agent",
        name="Security Agent",
        canned_output={"security": {"marker": "kept"}},
        started=started_security,
        release=deep_dive_release,
        recorder=[],
    )
    deep_dive_quality_agent = _BaseBarrierAgent(
        agent_id="quality-agent",
        name="Quality Agent",
        canned_output={"quality": {"marker": "kept"}},
        started=started_quality,
        release=deep_dive_release,
        recorder=[],
    )

    discovery_structure_team = _make_team(
        modules.team,
        name="structure",
        agents=[discovery_structure_agent],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )
    discovery_dependencies_team = _make_team(
        modules.team,
        name="dependencies",
        agents=[discovery_dependencies_agent],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )
    deep_dive_security_team = _make_team(
        modules.team,
        name="security",
        agents=[deep_dive_security_agent],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )
    deep_dive_quality_team = _make_team(
        modules.team,
        name="quality",
        agents=[deep_dive_quality_agent],
        bus=bus,
        event_store=event_store,
        aggregator=lambda outputs: {
            key: value for output in outputs for key, value in output.items()
        },
        tracer_provider=provider,
    )

    synthesis_report_payload = _sample_project_report_payload()
    synthesis_report_payload["summary"] = ""
    failing_synthesis = RecordingStubAgent(
        _build_stub_agent(
            modules.stubs,
            agent_id="report-agent",
            name="Report Agent",
            canned_output=synthesis_report_payload,
        )
    )

    orchestrator = _make_orchestrator(
        modules.orchestrator,
        discovery_structure_team=discovery_structure_team,
        discovery_dependencies_team=discovery_dependencies_team,
        deep_dive_security_team=deep_dive_security_team,
        deep_dive_quality_team=deep_dive_quality_team,
        synthesis_agent=failing_synthesis,
        validator=_make_validator(modules.orchestrator),
        event_store=event_store,
        snapshot_store=snapshot_store,
        bus=bus,
        tracer_provider=provider,
    )

    path = tmp_path / "failing.py"
    path.write_text("def demo():\n    return 1\n", encoding="utf-8")

    run_task = asyncio.create_task(orchestrator.run(str(path)))
    await asyncio.wait_for(started_discovery.wait(), timeout=1.0)
    await asyncio.wait_for(started_dependencies.wait(), timeout=1.0)
    discovery_release.set()
    await asyncio.wait_for(started_security.wait(), timeout=1.0)
    await asyncio.wait_for(started_quality.wait(), timeout=1.0)
    deep_dive_release.set()

    with pytest.raises(Exception):
        await asyncio.wait_for(run_task, timeout=1.0)

    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "team" in topic.lower() and "complete" in topic.lower()
            ]
        )
        == 4
    )
    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "phase" in topic.lower() and "valid" in topic.lower()
            ]
        )
        == 2
    )
    assert (
        len(
            [
                topic
                for topic, _ in bus.published
                if "phase" in topic.lower() and "fail" in topic.lower()
            ]
        )
        == 1
    )
    failure_messages = [
        message
        for topic, message in bus.published
        if "phase" in topic.lower() and "fail" in topic.lower()
    ]
    assert len(failure_messages) == 1
    failure_payload = _normalize_mapping(failure_messages[0].payload)
    assert _mapping_has_key_like(failure_payload, "rollback")

    workflow_id = getattr(orchestrator.analysis_state, "workflow_id", None)
    if workflow_id is None:
        workflow_ids = getattr(snapshot_store, "_workflow_index", {})
        workflow_id = next(iter(workflow_ids), None)
    assert workflow_id is not None
    history = await snapshot_store.history(workflow_id)
    assert history
    assert any(_contains_value(snapshot.state, "kept") for snapshot in history)
    assert any(_contains_value(snapshot.state, "discovery") for snapshot in history)
    assert _contains_value(orchestrator.analysis_state, "failed")
